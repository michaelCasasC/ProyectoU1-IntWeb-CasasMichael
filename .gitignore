## Visual Studio
indent_edge_soft_limit = 120
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,vb}]
#### ReSharper properties ####
resharper_csharp_indent_braces_outside_option = false
resharper_csharp_indent_case_label_braces = false
resharper_csharp_indent_switch_labels = true

[*.{js,json,yml,yaml}]
indent_size = 2

