@model SakilaApp.Models.Film

<h1>Nueva película</h1>

<form asp-action="Create">
    <div class="form-group">
        <label asp-for="Title">Título</label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="ReleaseYear">Año</label>
        <input asp-for="ReleaseYear" class="form-control" type="number" />
    </div>

    <div class="form-group">
        <label asp-for="Description">Descripción</label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
    </div>

    <button type="submit" class="btn btn-success mt-3">Guardar</button>
    <a href="@Url.Action("Index")" class="btn btn-secondary">Cancelar</a>
</form>